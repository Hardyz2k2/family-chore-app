{
  "name": "family-chore-app",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "bootstrap": "lerna bootstrap",
    "dev:web": "lerna run dev --scope=web-app",
    "dev:user-service": "lerna run dev --scope=user-service",
    "dev:chore-service": "lerna run dev --scope=chore-service",
    "dev:gamification-service": "lerna run dev --scope=gamification-service",
    "dev:ai-service": "lerna run dev --scope=ai-service",
    "dev:all-services": "lerna run dev --parallel --scope=*-service",
    "start:all-services": "lerna run start --parallel --scope=*-service",
    "build": "lerna run build",
    "build:web": "lerna run build --scope=web-app",
    "test": "lerna run test",
    "lint": "lerna run lint"
  },
  "devDependencies": {
    "lerna": "^8.1.2"
  }
}
