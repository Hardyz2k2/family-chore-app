# Database
DATABASE_URL=postgres://user:password@localhost:5432/family_chore_db

# JWT Secret
JWT_SECRET=your-super-secret-jwt-key-here

# AWS Configuration
AWS_REGION=us-east-1
S3_BUCKET_NAME=family-chore-assets

# OpenAI API Key (for voice AI)
OPENAI_API_KEY=sk-your-openai-api-key

# CORS Origin (for mobile app)
CORS_ORIGIN=*

# Node Environment
NODE_ENV=development

# Service Ports
USER_SERVICE_PORT=3001
CHORE_SERVICE_PORT=3002
GAMIFICATION_SERVICE_PORT=3003
AI_SERVICE_PORT=3004
